  },
  "homepage": "https://github.com/MagikbeeDev/eslint-config-magikbee-react-native#readme",
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": false,
    "trailingComma": "all"
  },
  "lint-staged": {
    "./app/**/*.{js,jsx,md,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.84.1",
