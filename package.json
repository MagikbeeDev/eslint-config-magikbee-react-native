{
  "name": "@magikbee/eslint-config-magikbee-react-native",
  "version": "1.1.3",
  "description": "",
  "keywords": [
    "typescript",
    "eslint",
    "eslintconfig"
  ],
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./prettier": "./prettier.config.cjs",
    "./tsconfig": "./tsconfig.json"
  },
  "files": [
    "index.js",
    ".eslintrc.js",
    "prettier.config.cjs",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MagikbeeDev/eslint-config-magikbee-react-native.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
